# ClickBit Staged — shared environment variables.
# Copy this file to .env and fill in the real values from the live ClickBit deployment.

# Supabase Postgres (must point at the same database used by the legacy clickbit API)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Connection pool tuning (mirrors clickbit/server/config/database.js)
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Redis (optional in dev; falls back to an in-memory store when unavailable)
REDIS_URL=redis://localhost:6379

# Supabase Auth (same values as clickbit/env.example)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Legacy custom JWT secret used by the clickbit Express API for non-Supabase tokens
JWT_SECRET=YOUR_JWT_SECRET

# API runtime
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3001

# Stripe (public payments / checkout)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Web app runtime (only public variables are sent to the browser)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
API_BASE_URL=http://localhost:5001
