  @@index([user_id], map: "idx_workspace_members_user_id")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model workspaces {
  id                Int                 @id @default(autoincrement())
  name              String              @db.VarChar(255)
  description       String?
  icon_url          String?
  created_by        Int
  settings          Json?               @default("{}") @db.Json
  created_at        DateTime?           @db.Timestamptz(6)
  updated_at        DateTime?           @db.Timestamptz(6)
  channels          channels[]
  workspace_members workspace_members[]
  profiles          profiles            @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "workspaces_owner_id_fkey")

  @@index([created_by], map: "idx_workspaces_owner_id")
  @@schema("public")
}

